# Base URL of the Traced API
TARGET_URL=

# Number of concurrent workers sending spans
WORKERS=

# How long the emitter runs before stopping (e.g. 30s, 5m)
DURATION=

# Rolling window in minutes, and must match your API's eviction window
WINDOW_MINUTES=

# Probability [0, 1) that spans within a batch are shuffled out of order
OUT_OF_ORDER_PROB=

# Maximum number of spans per ingest request
BATCH_SIZE=

# Average requests/second per worker (Poisson arrival model)
RATE_PER_WORKER=

# Run the verifier after emission finishes (true/false)
VERIFY=false
